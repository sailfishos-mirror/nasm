  "option": "--bits 16 -DERROR -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cfcmovl/",
  "target": [
   { "stderr": "cfcmovl.stderr16err" }
  ],
  "error": "expected"
 }
