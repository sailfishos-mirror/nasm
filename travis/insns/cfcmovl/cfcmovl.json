[
 {
  "description": "Pseudorandom test for CFCMOVL",
  "id": "cfcmovl64",
  "format": "bin",
  "source": "cfcmovl.asm",
  "option": "--bits 64 -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cfcmovl/",
  "target": [
   { "output": "cfcmovl.bin64", "match": "cfcmovl.bin64.t" }
  ]
 }
,
 {
  "description": "Pseudorandom error-case test for CFCMOVL",
  "id": "cfcmovl16err",
