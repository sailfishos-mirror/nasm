[
 {
  "description": "Pseudorandom test for CMOVL",
  "id": "cmovl64",
  "format": "bin",
  "source": "cmovl.asm",
  "option": "--bits 64 -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovl/",
  "target": [
   { "output": "cmovl.bin64", "match": "cmovl.bin64.t" }
  ]
 }
,
 {
  "description": "Pseudorandom error-case test for CMOVL",
  "id": "cmovl16err",
  "format": "bin",
  "source": "cmovl_narrow.asm",
  "option": "--bits 16 -DERROR -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovl/",
  "target": [
   { "stderr": "cmovl.stderr16err" }
  ],
  "error": "expected"
 }
,
 {
  "description": "Pseudorandom error-case test for CMOVL",
  "id": "cmovl32err",
  "format": "bin",
  "source": "cmovl_narrow.asm",
  "option": "--bits 32 -DERROR -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovl/",
  "target": [
   { "stderr": "cmovl.stderr32err" }
  ],
  "error": "expected"
 }
]
