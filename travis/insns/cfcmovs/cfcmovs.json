[
 {
  "description": "Pseudorandom test for CFCMOVS",
  "id": "cfcmovs64",
  "format": "bin",
  "source": "cfcmovs.asm",
  "option": "--bits 64 -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cfcmovs/",
  "target": [
   { "output": "cfcmovs.bin64", "match": "cfcmovs.bin64.t" }
  ]
 }
,
 {
  "description": "Pseudorandom error-case test for CFCMOVS",
  "id": "cfcmovs16err",
