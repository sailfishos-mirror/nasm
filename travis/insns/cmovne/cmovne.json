  "option": "--bits 16 -DERROR -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovne/",
  "target": [
   { "stderr": "cmovne.stderr16err" }
  ],
  "error": "expected"
 }
,
