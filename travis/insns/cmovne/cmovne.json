[
 {
  "description": "Pseudorandom test for CMOVNE",
  "id": "cmovne64",
  "format": "bin",
  "source": "cmovne.asm",
  "option": "--bits 64 -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovne/",
  "target": [
   { "output": "cmovne.bin64", "match": "cmovne.bin64.t" }
  ]
 }
,
 {
  "description": "Pseudorandom error-case test for CMOVNE",
  "id": "cmovne16err",
