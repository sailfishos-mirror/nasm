[
 {
  "description": "Pseudorandom test for CMOVNO",
  "id": "cmovno64",
  "format": "bin",
  "source": "cmovno.asm",
  "option": "--bits 64 -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovno/",
  "target": [
   { "output": "cmovno.bin64", "match": "cmovno.bin64.t" }
  ]
 }
,
 {
  "description": "Pseudorandom error-case test for CMOVNO",
  "id": "cmovno16err",
  "format": "bin",
  "source": "cmovno_narrow.asm",
  "option": "--bits 16 -DERROR -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovno/",
  "target": [
   { "stderr": "cmovno.stderr16err" }
  ],
  "error": "expected"
 }
,
 {
  "description": "Pseudorandom error-case test for CMOVNO",
