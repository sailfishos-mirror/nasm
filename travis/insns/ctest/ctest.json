  "source": "ctest_narrow.asm",
  "option": "--bits 16 -DERROR -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/ctest/",
  "target": [
   { "stderr": "ctest.stderr16err" }
  ],
  "error": "expected"
 }
,
