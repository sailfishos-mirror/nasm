  "format": "bin",
  "source": "cmovbe.asm",
  "option": "--bits 64 -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovbe/",
  "target": [
   { "output": "cmovbe.bin64", "match": "cmovbe.bin64.t" }
  ]
 }
