[
 {
  "description": "Pseudorandom test for CMOVS",
  "id": "cmovs64",
  "format": "bin",
  "source": "cmovs.asm",
  "option": "--bits 64 -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovs/",
  "target": [
   { "output": "cmovs.bin64", "match": "cmovs.bin64.t" }
  ]
 }
,
 {
  "description": "Pseudorandom error-case test for CMOVS",
  "id": "cmovs16err",
  "format": "bin",
  "source": "cmovs_narrow.asm",
  "option": "--bits 16 -DERROR -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovs/",
  "target": [
   { "stderr": "cmovs.stderr16err" }
  ],
  "error": "expected"
 }
,
 {
  "description": "Pseudorandom error-case test for CMOVS",
  "id": "cmovs32err",
  "format": "bin",
  "source": "cmovs_narrow.asm",
  "option": "--bits 32 -DERROR -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovs/",
  "target": [
   { "stderr": "cmovs.stderr32err" }
  ],
  "error": "expected"
 }
]
