  "source": "rcl.asm",
  "option": "--bits 64 -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/rcl/",
  "target": [
   { "output": "rcl.bin64", "match": "rcl.bin64.t" }
  ]
 }
