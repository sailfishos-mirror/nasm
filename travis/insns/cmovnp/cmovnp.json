  "option": "--bits 16 -DERROR -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovnp/",
  "target": [
   { "stderr": "cmovnp.stderr16err" }
  ],
  "error": "expected"
 }
,
