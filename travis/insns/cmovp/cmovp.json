[
 {
  "description": "Pseudorandom test for CMOVP",
  "id": "cmovp64",
  "format": "bin",
  "source": "cmovp.asm",
  "option": "--bits 64 -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovp/",
  "target": [
   { "output": "cmovp.bin64", "match": "cmovp.bin64.t" }
  ]
 }
,
 {
  "description": "Pseudorandom error-case test for CMOVP",
  "id": "cmovp16err",
  "format": "bin",
  "source": "cmovp_narrow.asm",
  "option": "--bits 16 -DERROR -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovp/",
  "target": [
   { "stderr": "cmovp.stderr16err" }
  ],
  "error": "expected"
 }
,
 {
  "description": "Pseudorandom error-case test for CMOVP",
  "id": "cmovp32err",
  "format": "bin",
  "source": "cmovp_narrow.asm",
  "option": "--bits 32 -DERROR -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovp/",
  "target": [
   { "stderr": "cmovp.stderr32err" }
  ],
  "error": "expected"
 }
]
