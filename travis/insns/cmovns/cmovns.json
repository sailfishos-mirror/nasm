[
 {
  "description": "Pseudorandom test for CMOVNS",
  "id": "cmovns64",
  "format": "bin",
  "source": "cmovns.asm",
  "option": "--bits 64 -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovns/",
  "target": [
   { "output": "cmovns.bin64", "match": "cmovns.bin64.t" }
  ]
 }
,
 {
  "description": "Pseudorandom error-case test for CMOVNS",
  "id": "cmovns16err",
