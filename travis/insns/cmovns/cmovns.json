  "option": "--bits 16 -DERROR -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovns/",
  "target": [
   { "stderr": "cmovns.stderr16err" }
  ],
  "error": "expected"
 }
,
