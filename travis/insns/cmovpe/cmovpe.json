[
 {
  "description": "Pseudorandom test for CMOVPE",
  "id": "cmovpe64",
  "format": "bin",
  "source": "cmovpe.asm",
  "option": "--bits 64 -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovpe/",
  "target": [
   { "output": "cmovpe.bin64", "match": "cmovpe.bin64.t" }
  ]
 }
,
 {
  "description": "Pseudorandom error-case test for CMOVPE",
  "id": "cmovpe16err",
  "format": "bin",
  "source": "cmovpe_narrow.asm",
  "option": "--bits 16 -DERROR -w-ea-absolute -w-implicit-abs-deprecated -I./travis/insns/cmovpe/",
  "target": [
   { "stderr": "cmovpe.stderr16err" }
  ],
  "error": "expected"
 }
,
 {
  "description": "Pseudorandom error-case test for CMOVPE",
